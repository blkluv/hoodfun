# Persist admin config on Vercel (pick one):

# A) Free Upstash Redis — best for instant Save without redeploy
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# B) GitHub commit to data/site-config.json (repo write token)
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=danyalsad/hoodfun
# GITHUB_BRANCH=main

# C) One-shot: paste Export JSON from /hm-ops (requires redeploy)
# SITE_CONFIG_JSON={"version":1,...}
